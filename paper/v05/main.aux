\citation{grimmett2001}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {Commitment Stability Phase Surface.} Stability $S(r,c)$ as a joint function of recursion depth $r$ and constraint strength $c$. Three structural regimes: the \textit  {drift zone} (low $c$, high $r$) where $\mathcal  {C}(T^n(S)) \ll \mathcal  {C}(S)$; the \textit  {compression stability} band (intermediate $c$) where surface stabilization occurs without full conservation; and the \textit  {conservation regime} (strong $c$, any $r$) where $\mathcal  {C}(T^n(S)) \approx \mathcal  {C}(S)$. The stability basin forms a ridge orthogonal to the recursion axis, constituting a structural invariant under recursive load. This figure is conceptual; the surface function is a structural analog of the empirical regime signatures in Figure~\ref {fig:L1-stability}.}}{18}{figure.5}\protected@file@percent }
\newlabel{fig:L2-phase}{{5}{18}{\textbf {Commitment Stability Phase Surface.} Stability $S(r,c)$ as a joint function of recursion depth $r$ and constraint strength $c$. Three structural regimes: the \textit {drift zone} (low $c$, high $r$) where $\mathcal {C}(T^n(S)) \ll \mathcal {C}(S)$; the \textit {compression stability} band (intermediate $c$) where surface stabilization occurs without full conservation; and the \textit {conservation regime} (strong $c$, any $r$) where $\mathcal {C}(T^n(S)) \approx \mathcal {C}(S)$. The stability basin forms a ridge orthogonal to the recursion axis, constituting a structural invariant under recursive load. This figure is conceptual; the surface function is a structural analog of the empirical regime signatures in Figure~\ref {fig:L1-stability}}{figure.5}{}}
\newlabel{thm:prob-fail}{{6.3}{18}{Probabilistic Transformations Fail Under Recursion}{theorem.6.3}{}}
\newlabel{lem:lineage}{{6.4}{18}{Lineage Prevents Forgery}{theorem.6.4}{}}
