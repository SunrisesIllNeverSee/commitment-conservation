\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces Total token expenditure across 5 turns. Baseline systems consume 230--316 tokens (growth). Enforcement systems consume 120--156 tokens (compression), a 32--48\% reduction. Enforcement 2 achieves the lowest total at 120 tokens---a 48\% reduction relative to Baseline 1 and 62\% relative to Baseline 2.}}{23}{figure.9}\protected@file@percent }
\newlabel{fig:total-comparison}{{9}{23}{Total token expenditure across 5 turns. Baseline systems consume 230--316 tokens (growth). Enforcement systems consume 120--156 tokens (compression), a 32--48\% reduction. Enforcement 2 achieves the lowest total at 120 tokens---a 48\% reduction relative to Baseline 1 and 62\% relative to Baseline 2}{figure.9}{}}
\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces Summary of baseline (B) vs.\ enforcement (E) token metrics across 5 turns. Enforcement systems achieve 32--48\% total token reduction while preserving the commitment kernel (obligation/amount/deadline).}}{23}{table.4}\protected@file@percent }
\newlabel{tab:concrete-results}{{4}{23}{Summary of baseline (B) vs.\ enforcement (E) token metrics across 5 turns. Enforcement systems achieve 32--48\% total token reduction while preserving the commitment kernel (obligation/amount/deadline)}{table.4}{}}
